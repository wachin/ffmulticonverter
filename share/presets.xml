<?xml version="1.0"?>
<presets>
  <AudioAAC128>
    <label>AAC audio 128 kbps</label>
    <params>-vn -c:a aac -b:a 128k -ar 48000 -ac 2</params>
    <extension>m4a</extension>
    <category>Audio</category>
  </AudioAAC128>
  <AudioAAC192>
    <label>AAC audio 192 kbps</label>
    <params>-vn -c:a aac -b:a 192k -ar 48000 -ac 2</params>
    <extension>m4a</extension>
    <category>Audio</category>
  </AudioAAC192>
  <AudioAC3Surround>
    <label>AC-3 surround 5.1</label>
    <params>-vn -c:a ac3 -b:a 448k -ar 48000 -ac 6</params>
    <extension>ac3</extension>
    <category>Audio</category>
  </AudioAC3Surround>
  <AudioFLAC>
    <label>FLAC lossless audio</label>
    <params>-vn -c:a flac</params>
    <extension>flac</extension>
    <category>Audio</category>
  </AudioFLAC>
  <AudioMP3High>
    <label>MP3 high quality</label>
    <params>-vn -c:a libmp3lame -q:a 2 -ar 48000 -ac 2</params>
    <extension>mp3</extension>
    <category>Audio</category>
  </AudioMP3High>
  <AudioMP3Portable>
    <label>MP3 portable 128 kbps</label>
    <params>-vn -c:a libmp3lame -b:a 128k -ar 44100 -ac 2</params>
    <extension>mp3</extension>
    <category>Audio</category>
  </AudioMP3Portable>
  <AudioOpusMusic>
    <label>Opus audio music 128 kbps</label>
    <params>-vn -c:a libopus -b:a 128k -vbr on -ar 48000 -ac 2</params>
    <extension>opus</extension>
    <category>Audio</category>
  </AudioOpusMusic>
  <AudioOpusVoice>
    <label>Opus audio voice 48 kbps mono</label>
    <params>-vn -c:a libopus -b:a 48k -application voip -ar 48000 -ac 1</params>
    <extension>opus</extension>
    <category>Audio</category>
  </AudioOpusVoice>
  <AudioWavPCM>
    <label>WAV PCM 48 kHz</label>
    <params>-vn -c:a pcm_s16le -ar 48000 -ac 2</params>
    <extension>wav</extension>
    <category>Audio</category>
  </AudioWavPCM>
  <CompatAVI>
    <label>AVI compatible MPEG-4 and MP3</label>
    <params>-c:v mpeg4 -q:v 4 -c:a libmp3lame -b:a 192k</params>
    <extension>avi</extension>
    <category>Compatibility</category>
  </CompatAVI>
  <CompatDVDNTSC>
    <label>DVD video NTSC</label>
    <params>-target ntsc-dvd</params>
    <extension>mpg</extension>
    <category>Compatibility</category>
  </CompatDVDNTSC>
  <CompatDVDPAL>
    <label>DVD video PAL</label>
    <params>-target pal-dvd</params>
    <extension>mpg</extension>
    <category>Compatibility</category>
  </CompatDVDPAL>
  <CompatMPEG4Mobile>
    <label>MP4 compatible MPEG-4 720p</label>
    <params>-vf scale=w=1280:h=720:force_original_aspect_ratio=decrease -c:v mpeg4 -q:v 5 -c:a aac -b:a 128k</params>
    <extension>mp4</extension>
    <category>Compatibility</category>
  </CompatMPEG4Mobile>
  <ExtractAudioAAC>
    <label>Extract audio to AAC</label>
    <params>-vn -c:a aac -b:a 192k</params>
    <extension>m4a</extension>
    <category>Extract</category>
  </ExtractAudioAAC>
  <ExtractAudioCopy>
    <label>Extract audio without re-encoding</label>
    <params>-vn -c:a copy</params>
    <extension>mka</extension>
    <category>Extract</category>
  </ExtractAudioCopy>
  <ExtractAudioFLAC>
    <label>Extract audio to FLAC</label>
    <params>-vn -c:a flac</params>
    <extension>flac</extension>
    <category>Extract</category>
  </ExtractAudioFLAC>
  <ExtractAudioMP3>
    <label>Extract audio to MP3</label>
    <params>-vn -c:a libmp3lame -q:a 2</params>
    <extension>mp3</extension>
    <category>Extract</category>
  </ExtractAudioMP3>
  <ExtractAudioOpus>
    <label>Extract audio to Opus</label>
    <params>-vn -c:a libopus -b:a 128k -vbr on</params>
    <extension>opus</extension>
    <category>Extract</category>
  </ExtractAudioOpus>
  <FastRemuxMKV>
    <label>Remux to MKV without re-encoding</label>
    <params>-map 0 -c copy</params>
    <extension>mkv</extension>
    <category>Remux</category>
  </FastRemuxMKV>
  <FastRemuxMP4>
    <label>Remux to MP4 without re-encoding</label>
    <params>-map 0 -c copy -movflags +faststart</params>
    <extension>mp4</extension>
    <category>Remux</category>
  </FastRemuxMP4>
  <VideoAV1Balanced>
    <label>AV1 MP4 balanced</label>
    <params>-c:v libsvtav1 -preset 6 -crf 32 -pix_fmt yuv420p -c:a aac -b:a 128k</params>
    <extension>mp4</extension>
    <category>AV1</category>
  </VideoAV1Balanced>
  <VideoAV1HighQuality>
    <label>AV1 MKV high quality</label>
    <params>-c:v libsvtav1 -preset 5 -crf 26 -pix_fmt yuv420p10le -c:a libopus -b:a 160k</params>
    <extension>mkv</extension>
    <category>AV1</category>
  </VideoAV1HighQuality>
  <VideoAV1Small>
    <label>AV1 WebM small file</label>
    <params>-c:v libaom-av1 -crf 34 -b:v 0 -cpu-used 6 -row-mt 1 -c:a libopus -b:a 96k</params>
    <extension>webm</extension>
    <category>AV1</category>
  </VideoAV1Small>
  <VideoH2641080p>
    <label>H.264 MP4 1080p</label>
    <params>-vf scale=w=1920:h=1080:force_original_aspect_ratio=decrease -c:v libx264 -preset medium -crf 22 -pix_fmt yuv420p -c:a aac -b:a 192k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.264</category>
  </VideoH2641080p>
  <VideoH264720p>
    <label>H.264 MP4 720p</label>
    <params>-vf scale=w=1280:h=720:force_original_aspect_ratio=decrease -c:v libx264 -preset medium -crf 23 -pix_fmt yuv420p -c:a aac -b:a 160k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.264</category>
  </VideoH264720p>
  <VideoH264Archive>
    <label>H.264 MKV archive quality</label>
    <params>-c:v libx264 -preset slow -crf 18 -pix_fmt yuv420p -c:a flac</params>
    <extension>mkv</extension>
    <category>H.264</category>
  </VideoH264Archive>
  <VideoH264Fast>
    <label>H.264 MP4 fast encode</label>
    <params>-c:v libx264 -preset veryfast -crf 24 -pix_fmt yuv420p -c:a aac -b:a 160k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.264</category>
  </VideoH264Fast>
  <VideoH264HighQuality>
    <label>H.264 MP4 high quality</label>
    <params>-c:v libx264 -preset slow -crf 18 -pix_fmt yuv420p -c:a aac -b:a 192k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.264</category>
  </VideoH264HighQuality>
  <VideoH264Social>
    <label>H.264 MP4 social media 1080p</label>
    <params>-vf scale=w=1920:h=1080:force_original_aspect_ratio=decrease -r 30 -c:v libx264 -preset medium -crf 21 -pix_fmt yuv420p -c:a aac -b:a 192k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.264</category>
  </VideoH264Social>
  <VideoH2651080p>
    <label>H.265 MP4 1080p</label>
    <params>-vf scale=w=1920:h=1080:force_original_aspect_ratio=decrease -c:v libx265 -preset medium -crf 26 -tag:v hvc1 -pix_fmt yuv420p -c:a aac -b:a 160k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.265</category>
  </VideoH2651080p>
  <VideoH2654K>
    <label>H.265 MP4 4K</label>
    <params>-vf scale=w=3840:h=2160:force_original_aspect_ratio=decrease -c:v libx265 -preset medium -crf 26 -tag:v hvc1 -pix_fmt yuv420p10le -c:a aac -b:a 192k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.265</category>
  </VideoH2654K>
  <VideoH265Archive>
    <label>H.265 MKV archive quality</label>
    <params>-c:v libx265 -preset slow -crf 22 -pix_fmt yuv420p10le -c:a flac</params>
    <extension>mkv</extension>
    <category>H.265</category>
  </VideoH265Archive>
  <VideoH265Small>
    <label>H.265 MP4 small file</label>
    <params>-c:v libx265 -preset slow -crf 28 -tag:v hvc1 -pix_fmt yuv420p -c:a aac -b:a 128k -movflags +faststart</params>
    <extension>mp4</extension>
    <category>H.265</category>
  </VideoH265Small>
  <VideoLosslessFFV1>
    <label>FFV1 lossless video archive</label>
    <params>-map 0 -c:v ffv1 -level 3 -g 1 -slicecrc 1 -c:a flac</params>
    <extension>mkv</extension>
    <category>Lossless</category>
  </VideoLosslessFFV1>
  <VideoLosslessH264>
    <label>H.264 lossless video</label>
    <params>-c:v libx264 -preset veryslow -crf 0 -pix_fmt yuv420p -c:a flac</params>
    <extension>mkv</extension>
    <category>Lossless</category>
  </VideoLosslessH264>
  <VideoProResHQ>
    <label>ProRes 422 HQ editing</label>
    <params>-c:v prores_ks -profile:v 3 -pix_fmt yuv422p10le -c:a pcm_s16le</params>
    <extension>mov</extension>
    <category>Editing</category>
  </VideoProResHQ>
  <VideoProResProxy>
    <label>ProRes proxy editing</label>
    <params>-c:v prores_ks -profile:v 0 -pix_fmt yuv422p10le -c:a pcm_s16le</params>
    <extension>mov</extension>
    <category>Editing</category>
  </VideoProResProxy>
  <VideoVP9Balanced>
    <label>VP9 WebM balanced</label>
    <params>-c:v libvpx-vp9 -b:v 0 -crf 32 -row-mt 1 -c:a libopus -b:a 128k</params>
    <extension>webm</extension>
    <category>VP9</category>
  </VideoVP9Balanced>
  <VideoVP9HighQuality>
    <label>VP9 WebM high quality</label>
    <params>-c:v libvpx-vp9 -b:v 0 -crf 24 -row-mt 1 -c:a libopus -b:a 160k</params>
    <extension>webm</extension>
    <category>VP9</category>
  </VideoVP9HighQuality>
  <VideoVP9Small>
    <label>VP9 WebM small file</label>
    <params>-c:v libvpx-vp9 -b:v 0 -crf 36 -row-mt 1 -c:a libopus -b:a 96k</params>
    <extension>webm</extension>
    <category>VP9</category>
  </VideoVP9Small>
</presets>
